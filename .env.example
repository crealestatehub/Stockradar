# ============================================================
# StockRadar — Variables de entorno
# Copia este archivo como .env.local para desarrollo local.
# En Railway, configura estas variables en el dashboard.
# ============================================================

# ─── BASE DE DATOS (Railway PostgreSQL) ─────────────────────
# Railway genera esta variable automáticamente al agregar
# un servicio PostgreSQL. Formato:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/stockradar"

# ─── AUTENTICACIÓN ──────────────────────────────────────────
# Cadena aleatoria larga para firmar los JWT.
# Genera una con: openssl rand -hex 32
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-larga-en-produccion"

# ─── APIS DE MERCADO ────────────────────────────────────────
# Si no configuras estas keys, la app corre en MODO DEMO
# con datos sintéticos (útil para desarrollo).

# Finnhub — cotizaciones y candles en tiempo real
# Plan gratuito: 60 req/min, datos con 15 min de retraso
# Registro: https://finnhub.io/register
FINNHUB_API_KEY=""

# Financial Modeling Prep — float y datos fundamentales
# Plan gratuito: 250 req/día
# Registro: https://financialmodelingprep.com/register
FMP_API_KEY=""

# ─── NEXT.JS ────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development
